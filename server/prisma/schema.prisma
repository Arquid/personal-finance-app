generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id           Int           @id @default(autoincrement())
  name         String
  type         String        // "checking", "savings", "credit"
  balance      Decimal       @default(0) @db.Decimal(12, 2)
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

model Category {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  color          String          @default("#6c5ce7")
  isCustom       Boolean         @default(false)
  transactions   Transaction[]
  budget         Budget?
  recurringBills RecurringBill[]
}

model Transaction {
  id          Int      @id @default(autoincrement())
  amount      Decimal  @db.Decimal(12, 2) // negative = expense, positive = income
  description String
  merchant    String?
  date        DateTime
  isRecurring Boolean  @default(false)
  createdAt   DateTime @default(now())

  accountId Int
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])

  @@index([date])
  @@index([categoryId])
}

model Budget {
  id          Int      @id @default(autoincrement())
  limitAmount Decimal  @db.Decimal(12, 2)
  period      String   @default("monthly") // "monthly", "weekly", "yearly"
  createdAt   DateTime @default(now())

  categoryId Int      @unique
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model Pot {
  id            Int      @id @default(autoincrement())
  name          String
  targetAmount  Decimal  @db.Decimal(12, 2)
  currentAmount Decimal  @default(0) @db.Decimal(12, 2)
  color         String   @default("#00b894")
  createdAt     DateTime @default(now())
}

model RecurringBill {
  id       Int     @id @default(autoincrement())
  name     String
  merchant String?
  amount   Decimal @db.Decimal(12, 2)
  dueDay   Int // day of month, e.g. 15
  isActive Boolean @default(true)

  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])
}
